{
  "name": "orbit",
  "version": "1.0.0",
  "description": "Orbit — menu bar meeting alerts with Google Calendar, Elgato lights, and Home Assistant phone push",
  "main": "tray.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "tray": "electron tray.js",
    "test-push": "node test-push.js",
    "dist:mac": "electron-builder --mac",
    "dist:mac-dir": "electron-builder --mac --dir"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "dotenv": "^16.3.1",
    "elgato-light-api": "^1.0.6",
    "express": "^5.1.0",
    "googleapis": "^126.0.1",
    "moment": "^2.29.4",
    "node-cron": "^3.0.3",
    "open": "^10.1.2"
  },
  "devDependencies": {
    "electron": "^42.0.0",
    "electron-builder": "^26.8.1",
    "nodemon": "^3.0.2"
  },
  "build": {
    "appId": "com.rjtuit.orbit",
    "productName": "Orbit",
    "files": [
      "tray.js",
      "index.js",
      "push.js",
      "audio-fix.js",
      "setup-auth.js",
      "assets/icon.png",
      "assets/hud.html",
      "assets/log.html",
      "sounds/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "sounds/**/*",
      "assets/hud.html"
    ],
    "extraResources": [
      {
        "from": ".env.example",
        "to": ".env.example"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64", "x64"]
        }
      ],
      "extendInfo": {
        "NSAppleEventsUsageDescription": "Orbit opens meeting links in your browser.",
        "NSLocalNetworkUsageDescription": "Orbit controls Elgato lights on your local network."
      },
      "icon": "assets/icon.png"
    },
    "extends": null,
    "directories": {
      "output": "dist"
    }
  },
  "keywords": [
    "google-calendar",
    "elgato",
    "meeting",
    "notifications",
    "lights"
  ],
  "author": "",
  "license": "MIT"
}
