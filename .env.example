# Google OAuth 2.0 credentials from https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth2callback

# Comma-separated list of Elgato Key Light / Light Strip IP addresses on your LAN
ELGATO_KEY_LIGHTS=192.168.1.100,192.168.1.101

# Calendar(s) to monitor. Use "primary" for the default, a specific calendar ID,
# or a comma-separated list to merge multiple calendars (e.g. work + personal).
CALENDAR_ID=primary

# IANA timezone, e.g. America/New_York, America/Los_Angeles, Europe/London
TIMEZONE=America/Los_Angeles

# Home Assistant phone push (Android companion app, bypasses DnD via alarm stream)
# Use your externally reachable URL (Nabu Casa or reverse proxy), not homeassistant.local
HA_URL=https://your-instance.ui.nabu.casa
HA_TOKEN=your_long_lived_access_token
# From Developer tools → Actions: "Send a notification via mobile_app_…"
# Or Entities: notify.pixel_8_pro → use mobile_app_pixel_8_pro
HA_NOTIFY_TARGET=mobile_app_your_phone_name

# Seconds of Mac idle time before treating you as "away" for phone push (default 300)
PUSH_AWAY_THRESHOLD_SECONDS=300

# Urgent push audio: tts (spoken title+message, default) or alarm_stream (alarm tone)
PUSH_URGENT_MODE=tts

# HA helper toggled when you tap Dismiss on a phone notification (see ha/meeting-notifier-dismiss.yaml)
HA_DISMISS_ENTITY=input_boolean.meeting_notifier_dismiss

# Fix Audio menu (requires: brew install switchaudio-osx)
AUDIO_OUTPUT_DEVICE=BlackHole 2ch
AUDIO_INPUT_DEVICE=Elgato Wave Link Chat Mix
WAVE_LINK_PROCESS=WaveLinkMacOS
WAVE_LINK_APP_PATH=/Applications/Elgato Wave Link.app
WAVE_LINK_BUNDLE_ID=com.elgato.WaveLink3
